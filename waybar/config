    "spacing": 5, // Gaps between modules (4px)

    "modules-left": [
        "custom/rofi",
        "hyprland/workspaces",
        //"hyprland/submap",
        //"temperature",
        //"idle_inhibitor",
        //"mpd"
        //"custom/spotify",
        "hyprland/window"
    ],
    "modules-center": [
        "clock#date"
        //"custom/weather"
        //"custom/gammastep"
    ],
    "modules-right": [
        // "custom/storage",
