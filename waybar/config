        "cpu",
        "backlight",
        "power-profiles-daemon",
        "battery",
        //"pulseaudio",
        "wireplumber",
        //"custom/screenshot_t",
        "tray",
        "custom/power"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "custom/sp1": {
        "format": " | ",
        "tooltip": false
    },
    "custom/sp2": {
        "format": " |",
        "tooltip": false
    },


    "custom/rofi": {
        "format": "’āē",
        "tooltip": false,
        //"on-click-right": "nwg-drawer",
        "on-click": "rofi -show run -modi window,run,combi -combi-modi window,run",
        "on-click-right": "pkill -9 rofi"
        //"on-click": "rofi --show run",
        //"on-click-middle": "pkill -9 wofi"
    },
    "custom/screenshot_t":{
        "format":"’Ć░ ",
        "on-click": "~/.config/hypr/scripts/screenshot_full",
        "on-click-right":"~/.config/hypr/scripts/screenshot_area"
    },

    "clock#1": {
        "format": "’ü│ {:%a}",
        "tooltip": false,
        "on-click": "gsimplecal"
    },
    "clock#2": {
        "format": "’ē┤ {:%d-%h-%Y}",
        "tooltip": false,
        "on-click": "gsimplecal"
    },
    "clock#3": {
        "format": "’ĆŚ {:%H:%M:%S %p}",
        "tooltip": false,
        "on-click": "gsimplecal"
    },

    "temperature": {
        // "thermal-zone": 1,
        "interval": 4,
        //"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "’ŗē {temperatureC}┬░C",
        "format-critical": "’ü▒  {temperatureC}┬░C",
        "format": "{icon}  {temperatureC}┬░C",
        "format-icons": ["’Ø½", "’ŗē", "’Ø®"],
        "max-length": 7,
        "min-length": 7,
        "on-click": "xsensors"
    },

    "memory": {
        "interval": 30,
        "format": "’ŗø  {used:0.2f} / {total:0.0f} GB",
        "on-click": "ghostty -e btop"
    },

    "battery": {
        "interval": 2,
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        // "format-charging": "’¢ā {capacity}%",
        // "format-plugged": "’ć” {capacity}%",
        "format-charging": "{icon} {capacity}%",
        "format-plugged": "{icon} {capacity}%",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ]
    },
    "network": {
        "format-wifi": "’ć½ {essid} ({signalStrength}%)",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ’×¢",
        "format-linked": "{ifname} (No IP) ’×¢",
        "format": "’ĆÆ",
        "format-disconnected": "’Üö",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "wl-copy $(ip address show up scope global | grep inet | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c5-)",
        "on-click-right": "wl-copy $(ip address show up scope global | grep inet6 | head -n1 | cut -d/ -f 1 | tr -d [:space:] | cut -c6-)",
        "tooltip-format": "’éō {bandwidthUpBits} ’ĆÖ {bandwidthDownBits}\n{ifname}\n{ipaddr}/{cidr}\n",
        "tooltip-format-wifi": "’ć½ {essid} {frequency}MHz\nStrength: {signaldBm}dBm ({signalStrength}%)\nIP: {ipaddr}/{cidr}\n’éō {bandwidthUpBits} ’ĆÖ {bandwidthDownBits}",
        "interval": 10
    },
    "custom/storage": {
        "format": "’éĀ {}",
        "format-alt": "{percentage}% ’éĀ",
        "format-alt-click": "click-right",
        "return-type": "json",
        "interval": 60,
        "exec": "~/.config/waybar/modules/storage.sh"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-alt": "{percent}% {icon}",
        "format-alt-click": "click-right",
        //"format-icons": ["’ā½", "’Ā┤"],
        "format-icons": ["’åģ", "’äæ"],
        "on-scroll-down": "brightnessctl s 5%-",
        "on-scroll-up": "brightnessctl s +5%"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        },
        "tooltip": "true"
    },
    "custom/weather": {
        "format": "{}",
        "format-alt": "{alt}: {}",
        "format-alt-click": "click-right",
        "interval": 3600,
        "exec": "curl -s 'https://wttr.in/?format=1'",
        //"return-type": "json",
        //"exec": "~/.config/waybar/modules/weather.sh",
        "exec-if": "ping wttr.in -c1"
    },
    "custom/pacman": {
        "format": "<big>¶Åå▓</big>  {}",
        "interval": 3600,                     // every hour
        "exec": "checkupdates | wc -l",       // # of updates
        "exec-if": "exit 0",                  // always run; consider advanced run conditions
        "on-click": "alacritty -e 'paru'; pkill -SIGRTMIN+8 waybar", // update system
        "signal": 8,
        "max-length": 5,
        "min-length": 3
    },

"custom/spotify": {
    "exec": "~/.config/waybar/mediaplayer.py --player spotify",
    "format": "{}  ’å╝",
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
},

    "custom/media": {
        "format": "{0} {1}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "’å╝",
            "default": "­¤Ä£"
        },
        "escape": true,
        //"exec": "~/.config/waybar/mediaplayer.py" // Script in resources folder
        // "exec": "~/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },

    "custom/power": {
        "format": " ¾░Éź ",
        "tooltip": false,
        // "on-click": "wlogout"
        "on-click": "~/.config/rofi/poweroff.sh"
    },

    "clock": {
        "tooltip": false,
        "format": "’ĆŚ  {:%H:%M  ’ü│ %e %b}",
        // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // "today-format": "<b>{}</b>",
        // "on-click": "gsimplecal"
        "on-click": "gsimplecal & (sleep 0.2 && while hyprctl activewindow | grep -q gsimplecal; do sleep 0.1; done; pkill gsimplecal) &"
    },

    "clock#date": {
        "tooltip": false,
        "format": "¾░źö  {:%I:%M %p - ’ü│ %e %b}",
        // "format": "¾░źö  {:%H:%M - ’ü│ %e %b}",
        // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // "today-format": "<b>{}</b>",
        // "on-click": "gsimplecal"
        "on-click": "gsimplecal & (sleep 0.2 && while hyprctl activewindow | grep -q gsimplecal; do sleep 0.1; done; pkill gsimplecal) &"

    },

    "custom/gammastep": {
      "interval": 5,
      "return-type": "json",
      "exec": {
        "pre": "if unit_status=\"$(systemctl --user is-active gammastep)\"; then\nstatus=\"$unit_status ($(journalctl --user -u gammastep.service -g 'Period: ' | tail -1 | cut -d ':' -f6 | xargs))\"\nelse\nstatus=\"$unit_status\"\nfi",
        "alt": "${status:-inactive}",
        "tooltip": "Gammastep is $status",
      },
      "format": "{icon}",
      "format-icons": {
        "activating": "¾░ü¬ ",
        "deactivating": "¾░ü¬ ",
        "inactive": "? ",
        "active (Night)": "’åå ",
        "active (Nighttime)": "’åå ",
        "active (Transition (Night)": "’åå ",
        "active (Transition (Nighttime)": "’åå ",
        "active (Day)": "ŅīŹ ",
        "active (Daytime)": "ŅīŹ ",
        "active (Transition (Day)": "ŅīŹ ",
        "active (Transition (Daytime)": "ŅīŹ ",
      },
      "on-click": "systemctl --user is-active gammastep && systemctl --user stop gammastep || systemctl --user start gammastep",
    },

    "cpu": {
        "interval": 1,
        //"format": "’ŗø {}%", // Icon: microchip
        "format": "{max_frequency}GHz <span color=\"darkgray\">| {usage}%</span>",
